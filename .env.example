# ---------------------------------------------------------------------------
# ardur-pipeline configuration. Copy to .env for local runs.
# Every value has a safe default; an empty .env produces a deterministic,
# budget=0 cycle that never makes a paid API call.
# ---------------------------------------------------------------------------

# Where the four engine repos are checked out (siblings by default). The
# orchestrator spawns each engine's CLI from `${ENGINES_DIR}/<engine>`.
ENGINES_DIR=..

# Engine directory names under ENGINES_DIR (override only if you renamed them).
ENGINE_AGGREGATOR=ardur-news-aggregator
ENGINE_RANKING=ardur-ranking-engine
ENGINE_TOP10=ardur-top10-engine
ENGINE_SYNTHESIZER=ardur-article-synthesizer

# Artifact store root. The site reads `${ARTIFACT_STORE}/latest/` + manifest.json.
ARTIFACT_STORE=.artifacts

# --- AI provider (forwarded to ranking + synthesizer) ----------------------
# deterministic = zero-cost, zero-network fallback. The CI/default path.
ARDUR_AI_PROVIDER=deterministic
# Hard cap on model calls per cycle. 0 => fully deterministic (budget=0).
ARDUR_AI_MAX_GENERATIONS=0
# Per-call model timeout (ms) before deterministic fallback kicks in.
ARDUR_AI_TIMEOUT_MS=20000

# --- Orchestration tuning --------------------------------------------------
# Per-stage spawn timeout (ms). Aggregation gets the longest budget.
STAGE_TIMEOUT_AGGREGATE_MS=600000
STAGE_TIMEOUT_RANK_MS=120000
STAGE_TIMEOUT_TOP10_MS=120000
STAGE_TIMEOUT_SYNTHESIZE_MS=900000

# Per-stage retry attempts (total tries = retries + 1) and backoff base (ms).
STAGE_RETRIES=2
STAGE_BACKOFF_MS=5000

# --- ETL (full-text fetch + fact extraction inside the aggregator) ---------
# Set to true to enable fetching source bodies for richer fact extraction.
ARDUR_ETL_ENABLED=false
# Per-article fetch+extraction timeout (ms) forwarded to the aggregator.
ARDUR_ETL_TIMEOUT_MS=30000

# --- Ollama (local / cloud LLM) --------------------------------------------
# Base URL of the Ollama API. Leave blank to skip Ollama.
OLLAMA_HOST=
# Model tag for Ollama inference, e.g. llama3.2
OLLAMA_MODEL=
# Bearer key for Ollama Cloud inference (leave blank for local).
OLLAMA_API_KEY=

# --- Hermes / MCP server ---------------------------------------------------
# Optional OpenAI-compatible Hermes proxy (safe allowlist forwarded to engines).
# Leave blank for CLI/PATH hermes or deterministic fallback.
GATEWAY_PROXY_URL=
GATEWAY_PROXY_KEY=
HERMES_PROXY_URL=
HERMES_PROXY_KEY=
HERMES_MODEL=
# Set to true to enable engine-spawning MCP tools (aggregate/rank/top10/synthesize).
# Default false — engine tools are opt-in; exposing them without auth is a risk.
HERMES_DARK_LAUNCH=false
# Path to the Hermes coverage SQLite DB (defaults to <ARTIFACT_STORE>/coverage.db).
HERMES_COVERAGE_DB=
# Bearer API key for MCP server authentication. Leave blank for local/trusted use only.
# IMPORTANT: set this if you expose the MCP server over any non-localhost transport.
MCP_API_KEY=

# --- Observability / alerting ----------------------------------------------
# Optional webhook (Slack-compatible) posted on a failed/degraded cycle.
ALERT_WEBHOOK_URL=
# Optional webhook receiving per-cycle CycleMetrics JSON (every cycle, all statuses).
METRICS_WEBHOOK_URL=
# Log format: json (machine, default) | pretty (human).
LOG_FORMAT=json

# --- Status / Kanban handoff (optional) ------------------------------------
# HTML or API URL of the umbrella issue to comment sanitized status events on.
ARDUR_KANBAN_ISSUE_URL=
# When true, a failed Kanban post fails the status reporter (default best-effort).
ARDUR_KANBAN_REQUIRED=false

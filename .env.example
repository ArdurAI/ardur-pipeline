# ---------------------------------------------------------------------------
# ardur-pipeline configuration. Copy to .env for local runs.
# Every value has a safe default; an empty .env produces a deterministic,
# budget=0 cycle that never makes a paid API call.
# ---------------------------------------------------------------------------

# Where the four engine repos are checked out (siblings by default). The
# orchestrator spawns each engine's CLI from `${ENGINES_DIR}/<engine>`.
ENGINES_DIR=..

# Engine directory names under ENGINES_DIR (override only if you renamed them).
ENGINE_AGGREGATOR=ardur-news-aggregator
ENGINE_RANKING=ardur-ranking-engine
ENGINE_TOP10=ardur-top10-engine
ENGINE_SYNTHESIZER=ardur-article-synthesizer

# Artifact store root. The site reads `${ARTIFACT_STORE}/latest/` + manifest.json.
ARTIFACT_STORE=.artifacts

# --- AI provider (forwarded to ranking + synthesizer) ----------------------
# deterministic = zero-cost, zero-network fallback. The CI/default path.
ARDUR_AI_PROVIDER=deterministic
# Hard cap on model calls per cycle. 0 => fully deterministic (budget=0).
ARDUR_AI_MAX_GENERATIONS=0
# Per-call model timeout (ms) before deterministic fallback kicks in.
ARDUR_AI_TIMEOUT_MS=20000

# --- Orchestration tuning --------------------------------------------------
# Per-stage spawn timeout (ms). Aggregation gets the longest budget.
STAGE_TIMEOUT_AGGREGATE_MS=600000
STAGE_TIMEOUT_RANK_MS=120000
STAGE_TIMEOUT_TOP10_MS=120000
STAGE_TIMEOUT_SYNTHESIZE_MS=900000

# Per-stage retry attempts (total tries = retries + 1) and backoff base (ms).
STAGE_RETRIES=2
STAGE_BACKOFF_MS=5000

# --- Observability / alerting ----------------------------------------------
# Optional webhook (Slack-compatible) posted on a failed/degraded cycle.
ALERT_WEBHOOK_URL=
# Log format: json (machine, default) | pretty (human).
LOG_FORMAT=json
